GPIO3.associatedPins[2].pin.$assign = "PA29";
GPIO3.associatedPins[3].$name       = "AIN4";
GPIO3.associatedPins[3].pin.$assign = "PA30";

GPIO4.$name                         = "road";
GPIO4.associatedPins.create(7);
GPIO4.associatedPins[0].$name       = "left33";
GPIO4.associatedPins[0].direction   = "INPUT";
