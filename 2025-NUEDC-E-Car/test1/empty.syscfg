GPIO2.associatedPins[3].$name            = "right_B";
GPIO2.associatedPins[3].direction        = "INPUT";
GPIO2.associatedPins[3].internalResistor = "PULL_UP";
GPIO2.associatedPins[3].pin.$assign      = "PA13";

GPIO3.$name                         = "MOTOR";
GPIO3.associatedPins.create(4);
GPIO3.associatedPins[0].$name       = "AIN1";
